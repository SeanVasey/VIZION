# =====================================================================
# VIZ(IO)N — environment template.  Copy to `.env.local` and fill in.
# NEVER commit real values. `.env*.local` is gitignored.
# =====================================================================

# --- Supabase (P2+) -------------------------------------------------
# Public (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses RLS, NEVER expose to the client:
SUPABASE_SERVICE_ROLE_KEY=

# --- Model providers (P3+) — server-side only -----------------------
# These keys must never reach the client. They are read exclusively
# inside Next route handlers (the provider-adapter proxy). Every key must
# also be added to the Vercel project env; until it is set, that
# provider's targets return 503 "not configured" (the rest keep working).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
# NEW with the 2026-07 thirteen-model roster:
DEEPSEEK_API_KEY=      # DeepSeek V4 (platform.deepseek.com)
LLAMA_API_KEY=         # Llama 4 Maverick (llama.developer.meta.com)
MINIMAX_API_KEY=       # MiniMax M2.7 (platform.minimax.io)
MOONSHOT_API_KEY=      # Kimi K2.6 (platform.moonshot.ai)
PERPLEXITY_API_KEY=    # Sonar Pro (perplexity.ai/settings/api)
DASHSCOPE_API_KEY=     # Qwen3.7 Max (Alibaba Cloud Model Studio, intl region)

# Model strings per target (overridable — keeps the adapter version-agnostic, D9).
# Defaults: claude-opus-5 / claude-sonnet-5 / gpt-5.6-sol / claude-fable-5
# / deepseek-chat / gemini-3.5-flash / Llama-4-Maverick-17B-128E-Instruct-FP8
# / MiniMax-M2.7 / mistral-large-latest / kimi-k2.6 / sonar-pro / qwen-max
# / grok-4.5.
MODEL_OPUS=
MODEL_SONNET=
MODEL_GPT=
MODEL_FABLE=
MODEL_DEEPSEEK=
MODEL_GEMINI=
MODEL_LLAMA=
MODEL_MINIMAX=
MODEL_MISTRAL=
MODEL_KIMI=
MODEL_SONAR=
MODEL_QWEN=
MODEL_GROK=
# Optional USD-per-1M-token pricing overrides used for the cost cap.
PRICE_OPUS_IN=
PRICE_OPUS_OUT=
PRICE_SONNET_IN=
PRICE_SONNET_OUT=
PRICE_GPT_IN=
PRICE_GPT_OUT=
PRICE_FABLE_IN=
PRICE_FABLE_OUT=
PRICE_DEEPSEEK_IN=
PRICE_DEEPSEEK_OUT=
PRICE_GEMINI_IN=
PRICE_GEMINI_OUT=
PRICE_LLAMA_IN=
PRICE_LLAMA_OUT=
PRICE_MINIMAX_IN=
PRICE_MINIMAX_OUT=
PRICE_MISTRAL_IN=
PRICE_MISTRAL_OUT=
PRICE_KIMI_IN=
PRICE_KIMI_OUT=
PRICE_SONAR_IN=
PRICE_SONAR_OUT=
PRICE_QWEN_IN=
PRICE_QWEN_OUT=
PRICE_GROK_IN=
PRICE_GROK_OUT=

# --- Per-user cost caps & rate limits (P3+) -------------------------
# Enforced server-side on every model route.
COST_CAP_USD_PER_DAY=2.00
RATE_LIMIT_PER_MIN=20

# --- Media (P5) -----------------------------------------------------
# Extraction pipeline: "proxy" (vision via the model proxy, default) or
# "ondevice" (fast, private, limited). Proxy needs ANTHROPIC_API_KEY.
NEXT_PUBLIC_MEDIA_EXTRACTION=proxy

# --- App ------------------------------------------------------------
# Canonical origin used for absolute URLs (OAuth redirects, share links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
